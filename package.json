{
  "name": "postal-code-lookup",
  "version": "1.0.0",
  "description": "市区町村名から郵便番号を検索するWebアプリケーション",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=property.test.ts --testPathIgnorePatterns=integration.test.ts",
    "test:property": "jest --testPathPattern=property.test.ts",
    "test:integration": "jest --testPathPattern=integration.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "postbuild": "cp -r public dist/ && cp -r data dist/"
  },
  "keywords": [
    "postal-code",
    "japan",
    "municipality",
    "search"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.5"
  }
}
